@model List<Secondary_School_Result_Management_System.Models.Entities.Term>
@{
    ViewData["Title"] = "Terms";
}

@if (TempData["Success"] != null)
{
    <div class="alert-edu-success">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
    </div>
}

<div class="section-header">
    <div>
        <div class="section-title">Terms</div>
        <div class="section-sub">Manage academic terms and sessions</div>
    </div>
    <a href="/Admin/CreateTerm" class="btn-accent">
        <i class="bi bi-plus-lg"></i> Add Term
    </a>
</div>

<div class="edu-card">
    @if (Model == null || !Model.Any())
    {
        <div style="text-align:center; padding:48px 0; color:var(--text-muted);">
            <i class="bi bi-calendar3" style="font-size:48px; display:block; margin-bottom:16px;"></i>
            <div style="font-size:15px; font-weight:600;">No terms yet</div>
            <div style="font-size:13px; margin-top:4px;">Add your first academic term to get started</div>
        </div>
    }
    else
    {
        <table class="edu-table">
            <thead>
                <tr>
                    <th>Term Name</th>
                    <th>Academic Session</th>
                    <th style="text-align:right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var term in Model)
                {
                    <tr>
                        <td style="font-weight:600;">@term.Name</td>
                        <td>
                            <span class="badge-edu badge-gold">@term.AcademicSession</span>
                        </td>
                        <td style="text-align:right;">
                            <form asp-action="DeleteTerm" asp-controller="Admin" method="post"
                                  style="display:inline;"
                                  onsubmit="return confirm('Delete @term.Name?')">
                                <input type="hidden" name="id" value="@term.Id" />
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-danger-sm">
                                    <i class="bi bi-trash3"></i> Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
